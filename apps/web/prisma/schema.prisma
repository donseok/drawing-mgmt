// Drawing Management System — Prisma schema
// 기반: docs/TRD.md §3
// pgvector는 raw SQL로 별도 활성화 (prisma/migrations/manual/pgvector.sql)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, vector]
}

// ─────────────────────────────────────────────────────────────
// USER · ORG · GROUP
// ─────────────────────────────────────────────────────────────
model User {
  id               String         @id @default(cuid())
  username         String         @unique
  passwordHash     String
  email            String?
  fullName         String
  organizationId   String?
  employmentType   EmploymentType @default(ACTIVE)
  role             Role           @default(USER)
  securityLevel    Int            @default(5) // 1(highest) ~ 5(lowest)
  signatureFile    String?
  failedLoginCount Int            @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  // F4-04 — soft-delete column. Active users have NULL; populated when the
  // user is hard-retired by an admin. `employmentType=RETIRED` is preserved
  // for HR/role analytics, but `deletedAt IS NOT NULL` is the canonical
  // signal that the account is gone (auth + picker queries filter on this).
  deletedAt        DateTime?
  // R33 / A-1 — Keycloak (OIDC) subject identifier. Populated on first OIDC
  // login (signIn callback in auth.ts). Independent of `username`/`email` so
  // an SSO user keeps the same row even if HR rewrites their handle.
  keycloakSub      String?        @unique
  // R37 / A-2 — SAML 2.0 NameID (Persistent identifier). Populated on first
  // SAML SSO login by the ACS endpoint (apps/web/app/api/v1/auth/saml/acs).
  // Mirrors the Keycloak/OIDC linkage above so SAML users keep a stable row
  // independent of username/email rewrites at the IdP.
  samlSub          String?        @unique
  // R35 / N-1 — per-user notification channel preferences. Today only the
  // email channel is toggleable (the in-app feed always receives), but this
  // generalizes cleanly to push/SMS columns later. Default true so existing
  // users keep parity with the old in-app-only behaviour (the global
  // `MAIL_ENABLED=0` env gate still suppresses sends in dev/CI).
  notifyByEmail    Boolean        @default(true)
  // R38 / N-2 — SMS + KakaoTalk 알림톡 channels.
  //
  // `phoneNumber` carries an E.164-ish digit string (the FE/zod regex tolerates
  // hyphens for KR-style display, "+82-10-..."). Nullable because most users
  // won't fill it in until they opt into SMS/Kakao push.
  //
  // Both `notifyBySms` and `notifyByKakao` default to FALSE — SMS / 알림톡
  // delivery costs real money via external providers (Twilio, NCP SENS), so
  // they must be explicitly opted in rather than inheriting the email
  // default. The global `SMS_ENABLED=0` / `KAKAO_ENABLED=0` env gate still
  // wins; these columns only matter when the env-level channel is on.
  phoneNumber      String?
  notifyBySms      Boolean        @default(false)
  notifyByKakao    Boolean        @default(false)

  organization       Organization?   @relation(fields: [organizationId], references: [id])
  groups             UserGroup[]
  ownedObjects       ObjectEntity[]  @relation("ObjectOwner")
  lockedObjects      ObjectEntity[]  @relation("ObjectLocker")
  approvalsRequested Approval[]      @relation("ApprovalRequester")
  approvalSteps      ApprovalStep[]
  activityLogs       ActivityLog[]
  chatSessions       ChatSession[]
  // R7 — workspace personalization. Pins are per-user shortcuts that drive
  // the home "핀 고정" panel and the search sidebar's 즐겨찾기 section.
  folderPins         UserFolderPin[]
  objectPins         UserObjectPin[]
  // R29 / N-1 — first-class notification feed. Replaces the previous
  // ActivityLog-derived synthesis so the bell badge and panel can show
  // genuine read/unread state.
  notifications      Notification[]
  // R31 / V-INF-2 — chunked uploads owned by this user. Cascade-delete so
  // wiping a user clears their dangling upload sessions (the on-disk temp
  // file is cleaned up by the cleanup worker / cancel endpoint, but a row
  // without an owner would just leak).
  uploads            Upload[]

  @@index([organizationId])
  @@index([role])
  @@index([deletedAt])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  parent   Organization?  @relation("OrgTree", fields: [parentId], references: [id])
  children Organization[] @relation("OrgTree")
  users    User[]

  @@index([parentId])
}

model Group {
  id          String      @id @default(cuid())
  name        String      @unique
  description String?
  createdAt   DateTime    @default(now())
  users       UserGroup[]
}

model UserGroup {
  userId  String
  groupId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
}

// ─────────────────────────────────────────────────────────────
// FOLDER · PERMISSION
// ─────────────────────────────────────────────────────────────
model Folder {
  id             String   @id @default(cuid())
  parentId       String?
  name           String
  folderCode     String   @unique
  defaultClassId String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parent       Folder?            @relation("FolderTree", fields: [parentId], references: [id])
  children     Folder[]           @relation("FolderTree")
  defaultClass ObjectClass?       @relation(fields: [defaultClassId], references: [id])
  permissions  FolderPermission[]
  objects      ObjectEntity[]
  // R7 — see UserFolderPin. Cascade so a folder delete also wipes user pins
  // pointing at it (avoids dangling references in personalization queries).
  pins         UserFolderPin[]

  @@index([parentId])
  @@index([folderCode])
}

model FolderPermission {
  id            String        @id @default(cuid())
  folderId      String
  principalType PrincipalType
  principalId   String
  // 권한 비트
  viewFolder    Boolean       @default(false)
  editFolder    Boolean       @default(false)
  viewObject    Boolean       @default(false)
  editObject    Boolean       @default(false)
  deleteObject  Boolean       @default(false)
  approveObject Boolean       @default(false)
  download      Boolean       @default(false)
  print         Boolean       @default(false)

  folder Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([folderId, principalType, principalId])
  @@index([principalType, principalId])
}

// ─────────────────────────────────────────────────────────────
// OBJECT (자료) · CLASS · ATTRIBUTE
// ─────────────────────────────────────────────────────────────
model ObjectEntity {
  id              String      @id @default(cuid())
  number          String      @unique // 도면번호
  name            String
  description     String?
  folderId        String
  classId         String
  securityLevel   Int         @default(5)
  state           ObjectState @default(NEW)
  ownerId         String
  currentRevision Int         @default(0)
  currentVersion  Decimal     @default(0.0) @db.Decimal(5, 1)
  lockedById      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  folder     Folder                 @relation(fields: [folderId], references: [id])
  class      ObjectClass            @relation(fields: [classId], references: [id])
  owner      User                   @relation("ObjectOwner", fields: [ownerId], references: [id])
  lockedBy   User?                  @relation("ObjectLocker", fields: [lockedById], references: [id])
  revisions  Revision[]
  attributes ObjectAttributeValue[]
  links      LinkedObject[]         @relation("LinkSource")
  linkedFrom LinkedObject[]         @relation("LinkTarget")
  activities ActivityLog[]
  pins       UserObjectPin[]

  @@index([folderId, state])
  @@index([number])
  @@index([ownerId])
  @@index([classId])
  @@index([state, deletedAt])
}

model ObjectClass {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  description String?
  attributes  ObjectAttribute[]
  folders     Folder[]
  objects     ObjectEntity[]
}

model ObjectAttribute {
  id           String   @id @default(cuid())
  classId      String
  code         String
  label        String
  dataType     AttrType
  required     Boolean  @default(false)
  defaultValue String?
  comboItems   Json?
  sortOrder    Int      @default(0)

  class  ObjectClass            @relation(fields: [classId], references: [id], onDelete: Cascade)
  values ObjectAttributeValue[]

  @@unique([classId, code])
  @@index([classId])
}

model ObjectAttributeValue {
  id          String @id @default(cuid())
  objectId    String
  attributeId String
  value       String

  object    ObjectEntity    @relation(fields: [objectId], references: [id], onDelete: Cascade)
  attribute ObjectAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([objectId, attributeId])
  @@index([attributeId, value])
}

model LinkedObject {
  id           String   @id @default(cuid())
  sourceId     String
  targetId     String
  relationType String?
  createdAt    DateTime @default(now())

  source ObjectEntity @relation("LinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target ObjectEntity @relation("LinkTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
}

// ─────────────────────────────────────────────────────────────
// USER PINS (워크스페이스 개인화) — R7
// ─────────────────────────────────────────────────────────────
// Per-user folder/object shortcuts. Order is preserved client-side via
// `sortOrder` so the user's drag-reorder stays after refresh.

model UserFolderPin {
  id        String   @id @default(cuid())
  userId    String
  folderId  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([userId, folderId])
  @@index([userId, sortOrder])
}

model UserObjectPin {
  id        String   @id @default(cuid())
  userId    String
  objectId  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  object ObjectEntity @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@unique([userId, objectId])
  @@index([userId, sortOrder])
}

// ─────────────────────────────────────────────────────────────
// REVISION · VERSION · ATTACHMENT
// ─────────────────────────────────────────────────────────────
model Revision {
  id        String   @id @default(cuid())
  objectId  String
  rev       Int
  createdAt DateTime @default(now())

  object   ObjectEntity @relation(fields: [objectId], references: [id], onDelete: Cascade)
  versions Version[]
  approval Approval?

  @@unique([objectId, rev])
}

model Version {
  id         String   @id @default(cuid())
  revisionId String
  ver        Decimal  @db.Decimal(5, 1)
  createdAt  DateTime @default(now())
  createdBy  String
  comment    String?

  revision    Revision     @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@unique([revisionId, ver])
}

model Attachment {
  id               String           @id @default(cuid())
  versionId        String
  filename         String
  storagePath      String           @unique
  mimeType         String
  size             BigInt
  isMaster         Boolean          @default(false)
  checksumSha256   String
  pdfPath          String?
  dxfPath          String?
  svgPath          String?
  thumbnailPath    String?
  conversionStatus ConversionStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  // R36 / V-INF-3 — ClamAV scan state. Lifecycle:
  //   PENDING  → SCANNING → CLEAN | INFECTED | FAILED
  //   PENDING  → SKIPPED   (CLAMAV_ENABLED=0 or binary missing)
  // Default PENDING so newly-created attachments visibly enter the scan queue
  // until the worker picks them up. INFECTED rows are blocked from
  // download/preview/print/thumbnail by the file-serving routes.
  virusScanStatus  VirusScanStatus  @default(PENDING)
  // ClamAV signature name (e.g. "Win.Trojan.Foo-1234"). Populated only when
  // virusScanStatus === INFECTED.
  virusScanSig     String?
  // Wallclock when the worker last finished a scan attempt (CLEAN/INFECTED/
  // SKIPPED/FAILED). Null until the first scan attempt completes.
  virusScanAt      DateTime?

  version        Version         @relation(fields: [versionId], references: [id], onDelete: Cascade)
  conversionJobs ConversionJob[]

  @@index([versionId])
  @@index([conversionStatus])
  @@index([virusScanStatus])
}

// ─────────────────────────────────────────────────────────────
// NUMBER RULE
// ─────────────────────────────────────────────────────────────
model NumberRule {
  id        String           @id @default(cuid())
  name      String
  classId   String?
  isDefault Boolean          @default(false)
  parts     NumberRulePart[]
}

model NumberRulePart {
  id      String   @id @default(cuid())
  ruleId  String
  type    PartType
  value   String?
  digits  Int?
  initial Int?
  order   Int

  rule NumberRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
}

// ─────────────────────────────────────────────────────────────
// APPROVAL
// ─────────────────────────────────────────────────────────────
model Approval {
  id          String         @id @default(cuid())
  revisionId  String         @unique
  title       String
  status      ApprovalStatus @default(PENDING)
  requesterId String
  createdAt   DateTime       @default(now())
  completedAt DateTime?

  revision  Revision       @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  requester User           @relation("ApprovalRequester", fields: [requesterId], references: [id])
  steps     ApprovalStep[]

  @@index([status, createdAt])
  @@index([requesterId])
}

model ApprovalStep {
  id            String     @id @default(cuid())
  approvalId    String
  approverId    String
  order         Int
  status        StepStatus @default(PENDING)
  comment       String?
  signatureFile String?
  actedAt       DateTime?

  approval Approval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  approver User     @relation(fields: [approverId], references: [id])

  @@unique([approvalId, order])
  @@index([approverId, status])
}

// ─────────────────────────────────────────────────────────────
// LOBBY
// ─────────────────────────────────────────────────────────────
model Lobby {
  id          String      @id @default(cuid())
  folderId    String
  title       String
  description String?
  expiresAt   DateTime?
  status      LobbyStatus @default(NEW)
  createdBy   String
  createdAt   DateTime    @default(now())

  attachments LobbyAttachment[]
  targets     LobbyTargetCompany[]
  // R19 — recipient reviews. Each reply transitions the lobby to IN_REVIEW
  // (when posted by a target) and is surfaced to the requester.
  replies     LobbyReply[]
}

model LobbyAttachment {
  id          String   @id @default(cuid())
  lobbyId     String
  filename    String
  storagePath String
  mimeType    String
  size        BigInt
  createdAt   DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
}

model LobbyTargetCompany {
  id        String @id @default(cuid())
  lobbyId   String
  companyId String

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, companyId])
}

// R19 — replies surface inside the lobby detail page so the requester can see
// recipient feedback. Decision flag separates plain comments from explicit
// approve/reject (used by the lobby status badge in the inbox).
model LobbyReply {
  id        String             @id @default(cuid())
  lobbyId   String
  userId    String
  comment   String
  decision  LobbyReplyDecision @default(COMMENT)
  createdAt DateTime           @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@index([lobbyId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// CONVERSION JOB
// ─────────────────────────────────────────────────────────────
model ConversionJob {
  id            String           @id @default(cuid())
  attachmentId  String
  status        ConversionStatus @default(PENDING)
  attempt       Int              @default(0)
  errorMessage  String?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime         @default(now())
  // R29 V-INF-6 — persistent paths for the conversion artifacts. The worker
  // already writes preview.dxf and thumbnail.png under
  // ${FILE_STORAGE_ROOT}/<attachmentId>/, but until R29 we never recorded the
  // paths on the row. Recording them lets routes/UI fan out (e.g. the
  // thumbnail streaming endpoint) without re-deriving the storage layout.
  // Both are nullable: a job that produced no thumbnail (PDF missing, DXF
  // generation failed) just leaves the field unset.
  dxfPath       String?
  thumbnailPath String?
  // R31 / P-1 — print pipeline reuses ConversionJob. `pdfPath` is the
  // resulting PDF on disk (typically `${FILE_STORAGE_ROOT}/<attachmentId>/preview.pdf`)
  // and `metadata` carries `{ kind: 'PRINT', ctb, pageSize }` so the worker
  // and status endpoint can distinguish PRINT requests from regular DWG
  // conversion jobs without a separate table. Both fields are nullable:
  // legacy DWG conversion jobs leave them unset.
  pdfPath       String?
  metadata      Json?

  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([attachmentId])
}

// ─────────────────────────────────────────────────────────────
// ACTIVITY · SYSTEM LOG · NOTICE
// ─────────────────────────────────────────────────────────────
model ActivityLog {
  id        String   @id @default(cuid())
  objectId  String?
  action    String
  userId    String
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  user   User          @relation(fields: [userId], references: [id])
  object ObjectEntity? @relation(fields: [objectId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([objectId, createdAt])
  @@index([action, createdAt])
}

// R29 / N-1 — Notification feed.
// `type` reuses the ActivityLog action vocabulary (OBJECT_CHECKIN, APPROVE,
// LOBBY_REPLY, ...) plus dedicated SYSTEM_* / USER_* codes for events that
// don't have a 1:1 ActivityLog row. `objectId` is denormalized so the FE
// can route a click without joining; if the related object is deleted we
// keep the notification (orphan link is acceptable, history > tidiness).
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  objectId  String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String
  category  String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([level, createdAt])
  @@index([category, createdAt])
}

model Notice {
  id          String    @id @default(cuid())
  title       String
  body        String
  isPopup     Boolean   @default(false)
  isActive    Boolean   @default(true)
  publishFrom DateTime
  publishTo   DateTime?
  createdAt   DateTime  @default(now())
}

// ─────────────────────────────────────────────────────────────
// CHAT (AI 챗봇)
// ─────────────────────────────────────────────────────────────
model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id          String   @id @default(cuid())
  sessionId   String
  role        ChatRole
  content     String
  toolCalls   Json?
  toolResults Json?
  tokensIn    Int?
  tokensOut   Int?
  model       String?
  mode        ChatMode
  createdAt   DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// 매뉴얼 RAG 청크 (pgvector). vector 컬럼은 raw SQL로 alter (prisma 미지원).
model ManualChunk {
  id        String   @id @default(cuid())
  source    String
  title     String
  content   String
  // embedding vector(1536) — raw SQL 마이그레이션로 alter
  updatedAt DateTime @updatedAt

  @@index([source])
}

// ─────────────────────────────────────────────────────────────
// UPLOAD (청크 업로드 세션) — R31 V-INF-2
// ─────────────────────────────────────────────────────────────
// Tracks an in-progress chunked upload. The on-disk temp file lives at
// `<UPLOAD_TMP_ROOT>/<id>.bin`. Once `uploadedBytes == totalBytes` and the
// finalize endpoint runs, the file is moved into the regular attachment
// storage layout and the row transitions to COMPLETED. Stale rows (PENDING
// past `expiresAt`) are reaped by a background sweep.
model Upload {
  id            String       @id @default(cuid())
  userId        String
  filename      String
  mimeType      String
  totalBytes    BigInt
  uploadedBytes BigInt       @default(0)
  storagePath   String
  status        UploadStatus @default(PENDING)
  errorMessage  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  expiresAt     DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────
// BACKUP (자동 백업 이력) — R33 D-5
// ─────────────────────────────────────────────────────────────
// Each backup attempt creates a row. `kind=POSTGRES` runs `pg_dump`,
// `kind=FILES` tars the FILE_STORAGE_ROOT. Lifecycle:
//   RUNNING → DONE (storagePath + sizeBytes populated)
//          → FAILED (errorMessage populated)
// The admin UI lists rows newest first. Retention sweep deletes both the
// row and the on-disk artifact past BACKUP_RETENTION_DAYS.
model Backup {
  id           String       @id @default(cuid())
  kind         BackupKind
  status       BackupStatus @default(RUNNING)
  storagePath  String?
  sizeBytes    BigInt?
  errorMessage String?
  startedAt    DateTime     @default(now())
  finishedAt   DateTime?

  @@index([kind, startedAt])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// API KEY (외부 연계)
// ─────────────────────────────────────────────────────────────
model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  prefix     String    @unique
  scopes     String[] // ["integration:read"]
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  createdBy  String
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────
enum Role {
  SUPER_ADMIN
  ADMIN
  USER
  PARTNER
}

enum EmploymentType {
  ACTIVE
  RETIRED
  PARTNER
}

enum ObjectState {
  NEW
  CHECKED_OUT
  CHECKED_IN
  IN_APPROVAL
  APPROVED
  DELETED
}

// F4-01 — `IN_PROGRESS` removed. PENDING covers both "waiting on the first
// approver" and "mid-approval"; the FE derives "in-progress" purely from
// step state (any APPROVED step + at least one PENDING step).
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// F4-02 — `WAITING` renamed to PENDING for symmetry with ApprovalStatus.
enum StepStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttrType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  COMBO
}

enum PartType {
  FOLDER_CODE
  LITERAL
  SEQUENCE
  YEAR
}

enum PrincipalType {
  USER
  ORG
  GROUP
}

enum LobbyStatus {
  NEW
  IN_REVIEW
  IN_APPROVAL
  COMPLETED
  EXPIRED
}

enum LobbyReplyDecision {
  COMMENT
  APPROVE
  REJECT
  REVISE_REQUESTED
}

enum ConversionStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum ChatRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum ChatMode {
  RAG
  RULE
}

// R31 / V-INF-2 — chunked upload session lifecycle.
//   PENDING     — row created, no chunks yet.
//   IN_PROGRESS — at least one chunk written, totalBytes not yet reached.
//   COMPLETED   — finalize() ran successfully (Attachment created).
//   FAILED      — explicit cancel by the owner OR finalize aborted.
//   EXPIRED     — past expiresAt without finalize; cleaned by background sweep.
enum UploadStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  EXPIRED
}

// R33 / D-5 — Backup row lifecycle.
//   POSTGRES — pg_dump of the application DB.
//   FILES    — tar of FILE_STORAGE_ROOT.
enum BackupKind {
  POSTGRES
  FILES
}

enum BackupStatus {
  RUNNING
  DONE
  FAILED
}

// R36 / V-INF-3 — Attachment ClamAV scan lifecycle.
//   PENDING  — row created, queued, worker hasn't picked it up.
//   SCANNING — worker started.
//   CLEAN    — exit 0, no signature.
//   INFECTED — exit 1, `virusScanSig` populated. Download/preview blocked.
//   SKIPPED  — CLAMAV_ENABLED=0 or `clamscan` binary unavailable.
//   FAILED   — exit 2 / I/O / unexpected error. Admin can retry.
enum VirusScanStatus {
  PENDING
  SCANNING
  CLEAN
  INFECTED
  SKIPPED
  FAILED
}
