# ───── Common ─────
DEPLOY_TARGET=onprem
NODE_ENV=development
LOG_LEVEL=info

# ───── DB (Postgres 16 + pgvector) ─────
DATABASE_URL=postgresql://drawmgmt:drawmgmt@localhost:5432/drawmgmt

# ───── Auth.js v5 ─────
AUTH_SECRET=please-change-32-char-secret-here-xxxxxxxx
NEXTAUTH_URL=http://localhost:3000
# R47 / FIND-004 — Dev-only plaintext fallback accounts (admin/admin123! 등).
# 운영(NODE_ENV=production)에서는 코드가 자동 차단하지만, 명시적으로 false로
# 두는 것이 권장. dev 환경 외에서는 어떤 경우에도 활성화하지 마십시오.
DEV_AUTH_FALLBACK=false

# ───── Keycloak / OIDC SSO (R33 A-1, optional) ─────
# 1 to enable the Keycloak provider on the login page; 0 (or unset) keeps
# Credentials-only auth. The NEXT_PUBLIC_ mirror is read by the FE login
# form to decide whether to render the "사내 SSO 로그인" button.
KEYCLOAK_ENABLED=0
NEXT_PUBLIC_KEYCLOAK_ENABLED=0
KEYCLOAK_ISSUER=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# ───── SAML 2.0 SSO (R37 A-2, optional) ─────
# 1 to expose /api/v1/auth/saml/{metadata,login,acs} and render the SAML
# button on the login page. 0 (or unset) returns 404 from the SAML routes
# and hides the FE button. NEXT_PUBLIC_SAML_ENABLED is the FE-side mirror.
SAML_ENABLED=0
NEXT_PUBLIC_SAML_ENABLED=0
# IdP single-sign-on entry URL (HTTP-Redirect binding).
SAML_IDP_ENTRY_POINT=
# IdP signing certificate. Either a single PEM blob (-----BEGIN CERTIFICATE-----)
# or a bare base64 body (header/footer auto-added). Multiple certs (rotation)
# may be passed as a `;`-separated list.
SAML_IDP_CERT=
# Our SP entity id — usually a URN registered with the IdP.
SAML_SP_ENTITY_ID=urn:drawing-mgmt
# Optional — PEM private key used to sign authn requests + decrypt
# encrypted assertions. Leave blank if the IdP doesn't require signed
# requests.
SAML_SP_PRIVATE_KEY=
# Optional — PEM public cert paired with the private key above. Republished
# in our SP metadata so the IdP can verify our request signatures.
SAML_SP_PUBLIC_CERT=
# ───── SAML SSO (R37 A-2, optional) ─────
# 1 to enable SAML SP routes (/api/v1/auth/saml/*) and render the SAML button
# on the login page. NEXT_PUBLIC_ mirror is read by the FE login form. The
# concrete IdP-binding env vars are configured by backend (see SAML_* in
# api_contract.md §3.1).
SAML_ENABLED=0
NEXT_PUBLIC_SAML_ENABLED=0
SAML_IDP_ENTRY_POINT=
SAML_IDP_CERT=
SAML_SP_ENTITY_ID=
SAML_SP_PRIVATE_KEY=

# ───── Backup (R33 D-5, optional) ─────
# Local directory the worker writes pg_dump / file tars into.
BACKUP_ROOT=./.data/backups
# Days before the retention sweep deletes a backup row + on-disk artifact.
BACKUP_RETENTION_DAYS=30
# 1 enables the daily repeatable BullMQ job in apps/worker (cron 0 2 * * *).
BACKUP_CRON_ENABLED=0

# ───── Files / Conversion (On-Prem) ─────
REDIS_URL=redis://localhost:6379
FILE_STORAGE_ROOT=./.data/files
ODA_CONVERTER_PATH=/opt/oda/ODAFileConverter
GS_PATH=/usr/bin/gs

# ───── Storage abstraction (R34 V-INF-1) ─────
# `local` = filesystem-backed (default, uses FILE_STORAGE_ROOT above).
# `s3`    = MinIO/S3-backed (set the S3_* vars below).
STORAGE_DRIVER=local
# S3 / MinIO settings (only consumed when STORAGE_DRIVER=s3).
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=drawing-mgmt
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# 1 = path-style URLs (required for MinIO). 0 = virtual-hosted (AWS S3).
S3_FORCE_PATH_STYLE=1

# ───── Mail (R35 N-1, optional) ─────
# Master gate. 1 enables SMTP send via the BullMQ `mail` queue worker;
# 0 (or unset) makes lib/mail.ts a no-op (logs the would-be send only).
# Per-user opt-out lives on `User.notifyByEmail` (PATCH /api/v1/me/preferences).
MAIL_ENABLED=0
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="drawing-mgmt <noreply@drawing-mgmt.local>"
# 1 forces TLS-on-connect (port 465). 0 = STARTTLS / plain (default 587).
SMTP_SECURE=0

# ───── SMS (R38 N-2, optional) ─────
# Master gate. 1 enables SMS send via the BullMQ `sms` queue worker;
# 0 (or unset) makes lib/sms.ts a no-op (logs the would-be send only).
# Per-user opt-in lives on `User.notifyBySms` + `User.phoneNumber`
# (PATCH /api/v1/me/preferences). External SMS API calls cost real money
# so the user-side default is OFF (vs. notifyByEmail=true).
SMS_ENABLED=0
# Driver: `twilio` (Apache 2.0 SDK) or `generic` (HTTP POST).
# Empty / `disabled` short-circuits to SKIPPED.
SMS_DRIVER=
# ─── Twilio (SMS_DRIVER=twilio) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
# ─── Generic HTTP (SMS_DRIVER=generic) ───
# Korean transactional SMS gateways (NCP-style, Aligo, etc.). Posts JSON
# `{ to, text }` with `Authorization: Bearer ${SMS_GENERIC_API_KEY}` if set.
SMS_GENERIC_ENDPOINT=
SMS_GENERIC_API_KEY=

# ───── KakaoTalk 알림톡 (R38 N-2, optional) ─────
# Master gate. 1 enables KakaoTalk Alimtalk send via the BullMQ `kakao`
# queue worker; 0 (or unset) makes lib/kakao.ts a no-op. Per-user opt-in
# lives on `User.notifyByKakao` + `User.phoneNumber`. KakaoTalk requires a
# pre-approved BizMessage `templateCode` — `KAKAO_DEFAULT_TEMPLATE_CODE`
# below is used by `enqueueNotification` for system-event fanouts. Without
# a populated templateCode the channel stays inert even when the user opts in.
KAKAO_ENABLED=0
# Driver: `ncp` (Naver Cloud Platform SENS Alimtalk) — generic HTTP.
# Empty / `disabled` short-circuits to SKIPPED.
KAKAO_DRIVER=
KAKAO_API_KEY=
# Sender / channel key (NCP `plusFriendId`).
KAKAO_SENDER_KEY=
# Full provider endpoint URL — e.g.
# https://sens.apigw.ntruss.com/alimtalk/v2/services/{serviceId}/messages
KAKAO_API_ENDPOINT=
# Pre-approved BizMessage template code used by enqueueNotification(). The
# template must declare `{name}`, `{title}`, `{body}`, `{link}` variables.
KAKAO_DEFAULT_TEMPLATE_CODE=

# ───── Integration ─────
INTEGRATION_API_KEY=please-change-integration-api-key

# ───── AI Chatbot ─────
CHAT_MODE=auto
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=1024
CHAT_RATE_LIMIT_PER_HOUR=30
CHAT_DAILY_TOKEN_BUDGET=2000000
RULE_FALLBACK_ON_LLM_ERROR=true

# ───── Chatbot RAG ─────
PGVECTOR_ENABLED=true
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
RAG_TOP_K=5

# ───── Viewer (R5/R10/R11/R12/R13) ─────
# 자체 DXF 엔진 default. 1=in-house (LINE/CIRCLE/ARC/LWPOLYLINE/TEXT/MTEXT/
# INSERT/HATCH solid/DIMENSION + Web Worker 파싱), 0=legacy dxf-viewer.
# R24부터 default 1로 전환. 문제 시 URL `?engine=legacy`로 per-tab override
# 가능, 또는 운영 환경 변수에서 0으로 강제.
NEXT_PUBLIC_USE_OWN_DXF_VIEWER=1

# ───── Vercel deployment (옵션) ─────
BLOB_READ_WRITE_TOKEN=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
EXTERNAL_CONVERTER_URL=
EXTERNAL_CONVERTER_KEY=
