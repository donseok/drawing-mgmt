# ───── Common ─────
DEPLOY_TARGET=onprem
NODE_ENV=development
LOG_LEVEL=info

# ───── DB (Postgres 16 + pgvector) ─────
DATABASE_URL=postgresql://drawmgmt:drawmgmt@localhost:5432/drawmgmt

# ───── Auth.js v5 ─────
AUTH_SECRET=please-change-32-char-secret-here-xxxxxxxx
NEXTAUTH_URL=http://localhost:3000

# ───── Keycloak / OIDC SSO (R33 A-1, optional) ─────
# 1 to enable the Keycloak provider on the login page; 0 (or unset) keeps
# Credentials-only auth. The NEXT_PUBLIC_ mirror is read by the FE login
# form to decide whether to render the "사내 SSO 로그인" button.
KEYCLOAK_ENABLED=0
NEXT_PUBLIC_KEYCLOAK_ENABLED=0
KEYCLOAK_ISSUER=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# ───── Backup (R33 D-5, optional) ─────
# Local directory the worker writes pg_dump / file tars into.
BACKUP_ROOT=./.data/backups
# Days before the retention sweep deletes a backup row + on-disk artifact.
BACKUP_RETENTION_DAYS=30
# 1 enables the daily repeatable BullMQ job in apps/worker (cron 0 2 * * *).
BACKUP_CRON_ENABLED=0

# ───── Files / Conversion (On-Prem) ─────
REDIS_URL=redis://localhost:6379
FILE_STORAGE_ROOT=./.data/files
ODA_CONVERTER_PATH=/opt/oda/ODAFileConverter
GS_PATH=/usr/bin/gs

# ───── Storage abstraction (R34 V-INF-1) ─────
# `local` = filesystem-backed (default, uses FILE_STORAGE_ROOT above).
# `s3`    = MinIO/S3-backed (set the S3_* vars below).
STORAGE_DRIVER=local
# S3 / MinIO settings (only consumed when STORAGE_DRIVER=s3).
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=drawing-mgmt
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# 1 = path-style URLs (required for MinIO). 0 = virtual-hosted (AWS S3).
S3_FORCE_PATH_STYLE=1

# ───── Mail (R35 N-1, optional) ─────
# Master gate. 1 enables SMTP send via the BullMQ `mail` queue worker;
# 0 (or unset) makes lib/mail.ts a no-op (logs the would-be send only).
# Per-user opt-out lives on `User.notifyByEmail` (PATCH /api/v1/me/preferences).
MAIL_ENABLED=0
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="drawing-mgmt <noreply@drawing-mgmt.local>"
# 1 forces TLS-on-connect (port 465). 0 = STARTTLS / plain (default 587).
SMTP_SECURE=0

# ───── Integration ─────
INTEGRATION_API_KEY=please-change-integration-api-key

# ───── AI Chatbot ─────
CHAT_MODE=auto
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=1024
CHAT_RATE_LIMIT_PER_HOUR=30
CHAT_DAILY_TOKEN_BUDGET=2000000
RULE_FALLBACK_ON_LLM_ERROR=true

# ───── Chatbot RAG ─────
PGVECTOR_ENABLED=true
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
RAG_TOP_K=5

# ───── Viewer (R5/R10/R11/R12/R13) ─────
# 자체 DXF 엔진 default. 1=in-house (LINE/CIRCLE/ARC/LWPOLYLINE/TEXT/MTEXT/
# INSERT/HATCH solid/DIMENSION + Web Worker 파싱), 0=legacy dxf-viewer.
# R24부터 default 1로 전환. 문제 시 URL `?engine=legacy`로 per-tab override
# 가능, 또는 운영 환경 변수에서 0으로 강제.
NEXT_PUBLIC_USE_OWN_DXF_VIEWER=1

# ───── Vercel deployment (옵션) ─────
BLOB_READ_WRITE_TOKEN=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
EXTERNAL_CONVERTER_URL=
EXTERNAL_CONVERTER_KEY=
